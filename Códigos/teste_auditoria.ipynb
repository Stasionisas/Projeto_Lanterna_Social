    "# Exemplo de cálculo de variação orçamentária\n",
    "previsto = 1500000.00\n",
    "realizado = 1350000.00\n",
    "\n",
    "variacao = ((realizado - previsto) / previsto) * 100\n",
    "\n",
    "print(f\"Orçamento Previsto: R$ {previsto:,.2f}\")\n",
    "print(f\"Orçamento Realizado: R$ {realizado:,.2f}\")\n",
    "print(f\"Variação: {variacao:.2f}%\")\n",
    "\n",
    "if realizado < previsto:\n",
    "    print(\"\\n✅ Economia detectada ou subexecução.\")\n",
    "else:\n",
    "    print(\"\\n⚠️ Atenção: Gasto acima do previsto.\")"
   ]
  }
